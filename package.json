{
  "name": "connect4",
  "version": "0.1.2",
  "private": true,
  "description": "connect4",
  "author": "Alex Sav",
  "main": "index.js",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "ws": "node devtools/ws-server.js",
    "start": "webpack serve --config webpack_configs/webpack.config.js --mode development",
    "all": "npm-run-all -p -r ws start",
    "android": "webpack --config webpack_configs/android.webpack.config.js --mode production",
    "build": "webpack --config webpack_configs/production.webpack.config.js --mode production",
    "style": "npx eslint . -c linters/eslint.config.js",
    "style:fix": "npx eslint . -c linters/eslint.config.js --fix",
    "style2": "npx stylelint --config linters/stylelint.config.js \"src/**/*.css\"",
    "style2:fix": "npx stylelint --config linters/stylelint.config.js \"src/**/*.css\" --fix",
    "test": "node --test --test-reporter dot",
    "test:verbose": "node --test",
    "test:watch": "node --test --watch",
    "test:coverage": "c8 node --test --test-reporter dot",
    "updates": "npx ncu",
    "updates:fix": "npx ncu -u && npm install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asavan/connect4.git"
  },
  "homepage": "https://asavan.github.io/connect4/",
  "devDependencies": {
    "netdeps": "github:asavan/net-deps#v0.0.5"
  },
  "dependencies": {
    "connect-four-ai-wasm": "^1.0.0",
    "netutils": "github:asavan/netutils#v0.1.5"
  }
}
